{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "jsx": "react-native",
    "lib": [
      "es2020",
      "dom"
    ],
    "module": "esnext",
    "target": "es2020",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/constants": [
        "./constants"
      ],
      "@/store": [
        "./store"
      ],
      "@/lib": [
        "./lib"
      ],
      "@/components": [
        "./components"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "server",
    "aura-dating-main",
    "supabase/functions"
  ],
  "extends": "expo/tsconfig.base"
}
